{
  "name": "codex-quiz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint --error-on-warnings src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "quiz:check": "vitest run src/quizValidation.test.ts",
    "type-coverage": "type-coverage --at-least 95 --strict",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run type-coverage && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16",
    "typescript": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "type-coverage": "^2.29.7",
    "vitest": "^4.1.8"
  }
}
